FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_PASSWORD=
# Where the demo Parquet lives after ./scripts/unzip-data.sh. Defaults to the
# repo's data/ dir; uncomment to override.
# XGRAPH_DATA_DIR=/abs/path/to/data
KINETICA_URL=http://127.0.0.1:9191
KINETICA_USER=admin
KINETICA_PASS=
# Optional LLM overrides (default backend is the `claude` CLI on PATH):
# XGRAPH_LLM_MODEL=claude-opus-4-7            # ask/explain model (default: CLI default)
# XGRAPH_EXTRACT_MODEL=claude-haiku-4-5-20251001  # extraction + fold-checks (default: Haiku, fast)
# XGRAPH_LLM_TIMEOUT=180
